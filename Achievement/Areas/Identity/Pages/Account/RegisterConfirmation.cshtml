@page "/RegisterConfirmation"
@model RegisterConfirmationModel
@{
    ViewData["Title"] = "Confirmação de registo";
}

<div class="auth-wrap">
    <div class="auth-card">
        <h1 class="auth-title">Confirmação de registo</h1>
        @if (Model.DisplayConfirmAccountLink)
        {
            <p class="auth-message">
                Este site não tem um serviço de email configurado.
                Normalmente receberias um email — usa este link para confirmar a conta:
                <a id="confirm-link" href="@Model.EmailConfirmationUrl">Confirmar a minha conta</a>
            </p>
        }
        else
        {
            <p class="auth-message">Confirma o teu email para ativares a conta. Verifica a tua caixa de entrada.</p>
        }
        <div class="auth-links">
            <a asp-page="./Login">Entrar</a>
        </div>
    </div>
</div>
