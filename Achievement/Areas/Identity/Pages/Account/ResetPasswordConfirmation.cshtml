@page "/ResetPasswordConfirmation"
@model ResetPasswordConfirmationModel
@{
    ViewData["Title"] = "Palavra-passe redefinida";
}

<div class="auth-wrap">
    <div class="auth-card">
        <h1 class="auth-title">Palavra-passe redefinida</h1>
        <p class="auth-message">A tua palavra-passe foi redefinida com sucesso.</p>
        <div class="auth-links">
            <a asp-page="./Login">Entrar</a>
        </div>
    </div>
</div>
