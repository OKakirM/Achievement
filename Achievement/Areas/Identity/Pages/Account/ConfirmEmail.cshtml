@page "/ConfirmEmail"
@model ConfirmEmailModel
@{
    ViewData["Title"] = "Confirmar email";
}

<div class="auth-wrap">
    <div class="auth-card">
        <h1 class="auth-title">Confirmar email</h1>
        <partial name="_StatusMessage" model="Model.StatusMessage" />
        <div class="auth-links">
            <a asp-page="./Login">Entrar</a>
        </div>
    </div>
</div>
