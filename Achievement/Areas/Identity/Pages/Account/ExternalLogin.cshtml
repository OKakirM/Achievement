@page "/ExternalLogin"
@model ExternalLoginModel
@{
    ViewData["Title"] = "Associar conta";
}

<div class="auth-wrap">
    <div class="auth-card">
        <h1 class="auth-title">Associar conta</h1>
        <p class="auth-subtitle" id="external-login-title">Associa a tua conta @Model.ProviderDisplayName.</p>

        <p class="auth-message" id="external-login-description">
            Autenticaste-te com sucesso através de <strong>@Model.ProviderDisplayName</strong>.
            Introduz um email para finalizares o registo neste site.
        </p>

        <form asp-page-handler="Confirmation" asp-route-returnUrl="@Model.ReturnUrl" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
            <div class="form-floating mb-3">
                <input asp-for="Input.Email" class="form-control" autocomplete="email" placeholder="name@example.com" />
                <label asp-for="Input.Email">E-Mail</label>
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>
            <button type="submit" class="btn-accent auth-submit">Concluir registo</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
