@page "/ForgotPasswordConfirmation"
@model ForgotPasswordConfirmation
@{
    ViewData["Title"] = "Verifica o teu email";
}

<div class="auth-wrap">
    <div class="auth-card">
        <h1 class="auth-title">Verifica o teu email</h1>
        <p class="auth-message">Enviámos-te um link para redefinires a palavra-passe. Confirma a tua caixa de entrada.</p>
        <div class="auth-links">
            <a asp-page="./Login">Voltar a entrar</a>
        </div>
    </div>
</div>
