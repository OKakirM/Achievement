@page "/ForgotPassword"
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Recuperar palavra-passe";
}

<div class="auth-wrap">
    <div class="auth-card">
        <h1 class="auth-title">Recuperar palavra-passe</h1>
        <p class="auth-subtitle">Introduz o teu email e enviamos-te um link para redefinir.</p>

        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
            <div class="form-floating mb-3">
                <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                <label asp-for="Input.Email">E-Mail</label>
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>
            <button type="submit" class="btn-accent auth-submit">Redefinir palavra-passe</button>
        </form>

        <div class="auth-links">
            <a asp-page="./Login">Voltar a entrar</a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
