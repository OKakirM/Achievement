@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<h1>@ViewData["Title"]</h1>

<div class="row">
    <div class="col-md-4">
        <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
            <h2>Criar uma novo utilizador.</h2>
            <hr />
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
            <div class="form-floating mb-3">
                <input asp-for="Input.UserData.Name" class="form-control" autocomplete="username" aria-required="true" placeholder="Name" />
                <label asp-for="Input.UserData.Name">Nome do Utilizador</label>
                <span asp-validation-for="Input.UserData.Name" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Input.UserData.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                <label asp-for="Input.UserData.Email">E-Mail</label>
                <span asp-validation-for="Input.UserData.Email" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Input.UserData.Password" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Palavra-Passe" />
                <label asp-for="Input.UserData.Password">Palavra-Passe</label>
                <span asp-validation-for="Input.UserData.Password" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Input.UserData.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Palavra-Passe" />
                <label asp-for="Input.UserData.ConfirmPassword">Confirmar Palavra-Passe</label>
                <span asp-validation-for="Input.UserData.ConfirmPassword" class="text-danger"></span>
            </div>
            <button id="registerSubmit" type="submit" class="w-100 btn btn-lg btn-primary">Register</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
