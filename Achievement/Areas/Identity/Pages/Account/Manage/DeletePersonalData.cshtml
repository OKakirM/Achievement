@page
@model DeletePersonalDataModel
@{
    ViewData["Title"] = "Eliminar dados pessoais";
    ViewData["ActivePage"] = ManageNavPages.PersonalData;
}

<h3>Eliminar dados pessoais</h3>

<div class="alert alert-warning" role="alert">
    <p class="mb-0"><strong>Eliminar estes dados remove permanentemente a tua conta. Esta ação não pode ser revertida.</strong></p>
</div>

<form id="delete-user" method="post" class="settings-form">
    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
    @if (Model.RequirePassword)
    {
        <div class="form-floating mb-3">
            <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="Palavra-passe" />
            <label asp-for="Input.Password">Palavra-passe</label>
            <span asp-validation-for="Input.Password" class="text-danger"></span>
        </div>
    }
    <button class="btn btn-danger auth-submit" type="submit">Eliminar dados e fechar a conta</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
