@page "/Users/Manage/PersonalData"
@model PersonalDataModel
@{
    ViewData["Title"] = "Dados pessoais";
    ViewData["ActivePage"] = ManageNavPages.PersonalData;
}

<h3>Dados pessoais</h3>

<p>A tua conta contém dados pessoais que nos forneceste. Aqui podes transferir ou eliminar esses dados.</p>

<form id="download-data" asp-page="DownloadPersonalData" method="post">
    <button class="btn-accent" type="submit"><i class="bi bi-download"></i> Transferir os meus dados</button>
</form>

<div class="danger-zone">
    <h4 class="mt-0">Eliminar conta</h4>
    <p class="mb-3"><strong>Eliminar estes dados remove permanentemente a tua conta. Esta ação não pode ser revertida.</strong></p>
    <a id="delete" asp-page="DeletePersonalData" class="btn btn-danger">Eliminar conta</a>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
