@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using Achievement.Data
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager
@inject ApplicationDbContext Db

<ul class="navbar-nav">
@if (SignInManager.IsSignedIn(User))
{
    var idUser = await UserManager.GetUserAsync(User);
    var profile = idUser?.Email != null
        ? await Db.Users.AsNoTracking().FirstOrDefaultAsync(u => u.Email == idUser.Email)
        : null;
    var displayName = profile?.Name ?? User.Identity?.Name;

    <li class="nav-item dropdown">
        <a class="nav-link dropdown-toggle d-flex align-items-center gap-2" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
            <span class="nav-avatar">
                @if (string.IsNullOrEmpty(profile?.Image))
                {
                    <span class="nav-avatar-initials">@((displayName ?? "?").Substring(0, 1).ToUpper())</span>
                }
                else
                {
                    <img src="~/@profile!.Image" alt="Avatar" />
                }
            </span>
            <span>@displayName</span>
        </a>
        <ul class="dropdown-menu dropdown-menu-dark dropdown-menu-end" aria-labelledby="userDropdown">
            @if (profile != null)
            {
                <li><a class="dropdown-item" asp-area="" asp-page="/Users/Details" asp-route-id="@profile.Id">A minha lista</a></li>
            }
            <li><a class="dropdown-item" asp-area="Identity" asp-page="/Account/Manage/Index">Configurações da conta</a></li>
            <li><hr class="dropdown-divider"></li>
            <li>
                <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/Index", new { area = "" })">
                    <button type="submit" class="dropdown-item">Terminar sessão</button>
                </form>
            </li>
        </ul>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link" asp-area="Identity" asp-page="/Account/Register">Registar</a>
    </li>
    <li class="nav-item">
        <a class="nav-link" asp-area="Identity" asp-page="/Account/Login">Entrar</a>
    </li>
}
</ul>
