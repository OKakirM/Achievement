<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Achievement</title>
    <script type="importmap"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Sora:wght@600;700;800&display=swap" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Achievement.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark border-bottom box-shadow">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Index">Achievement</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Index">Início</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="jogosDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">Jogos<i class="bi bi-chevron-down nav-caret"></i></a>
                            <ul class="dropdown-menu dropdown-menu-dark" aria-labelledby="jogosDropdown">
                                <li><a class="dropdown-item" asp-area="" asp-page="/Games/Index">Todos os Jogos</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-page="/Genres/Index">Géneros</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-page="/Platforms/Index">Plataformas</a></li>
                            </ul>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Reviews/Index">Reviews</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Users/Index">Lista dos Utilizadores</a>
                        </li>
                    </ul>
                    <span class="navbar-text me-3 d-flex align-items-center gap-1" title="Pessoas online">
                        <i class="bi bi-circle-fill text-success online-dot mx-1" style="font-size:.6rem"></i>
                        <span><span id="onlineNum">–</span> online</span>
                    </span>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>
    @if (TempData["Success"] != null)
    {
        <div class="toast-host">
            <div class="toast-pop">@TempData["Success"]</div>
        </div>
    }

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="site-footer">
        <div class="container">
            <div class="footer-grid">
                <div class="footer-brand">
                    <a class="footer-logo" asp-area="" asp-page="/Index">Achievement</a>
                    <p class="footer-tagline">Regista, avalia e descobre os jogos que jogaste.</p>
                </div>
                <nav class="footer-col">
                    <h3 class="footer-col-title">Explorar</h3>
                    <a asp-area="" asp-page="/Games/Index">Jogos</a>
                    <a asp-area="" asp-page="/Genres/Index">Géneros</a>
                    <a asp-area="" asp-page="/Platforms/Index">Plataformas</a>
                </nav>
                <nav class="footer-col">
                    <h3 class="footer-col-title">Comunidade</h3>
                    <a asp-area="" asp-page="/Reviews/Index">Reviews</a>
                    <a asp-area="" asp-page="/Users/Index">Lista dos Utilizadores</a>
                </nav>
            </div>
            <div class="footer-bottom">
                <span>&copy; 2026 Achievement</span>
                <a asp-area="" asp-page="/Privacy">Privacidade</a>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <!-- Código adaptado de
     https://learn.microsoft.com/en-us/aspnet/core/signalr/javascript-client?view=aspnetcore-10.0&tabs=visual-studio
    -->
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@8/dist/browser/signalr.min.js"></script>
    <script>
        const presence = new signalR.HubConnectionBuilder().withUrl("/hubs/presence").withAutomaticReconnect().build();
        presence.on("online", n => document.getElementById("onlineNum").textContent = n);
        presence.start().catch(console.error);
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
