@page
@model Achievement.Pages.Users.DeleteModel

@{
    ViewData["Title"] = "Eliminar Utilizador";
}

<div class="form-page">
<div class="page-header">
    <h1 class="page-title">Eliminar Utilizador</h1>
</div>

<div class="content-card">
    <h4 class="mb-3" style="color: var(--danger);">Tens a certeza que queres eliminar este utilizador?</h4>
    <p class="form-hint mb-4">Esta ação remove também a conta de acesso (login) e as imagens do perfil. Não pode ser desfeita.</p>

    <div class="d-flex gap-3 flex-wrap mb-3 align-items-center">
        <div class="user-avatar" style="margin:0;">
            @if (!string.IsNullOrWhiteSpace(Model.User.Image))
            {
                <img src="~/@Model.User.Image" alt="Avatar de @Model.User.Name" />
            }
            else
            {
                <span class="user-avatar-initial">@(Model.User.Name.Length > 0 ? Model.User.Name[0].ToString().ToUpper() : "?")</span>
            }
        </div>

        <dl class="row flex-grow-1 mb-0">
            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.User.Name)</dt>
            <dd class="col-sm-9">@Model.User.Name @(Model.IsAdmin ? "(Administrador)" : "")</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.User.Email)</dt>
            <dd class="col-sm-9">@Model.User.Email</dd>

            <dt class="col-sm-3">Jogos na lista</dt>
            <dd class="col-sm-9">@Model.GamesCount</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.User.CreatedAt)</dt>
            <dd class="col-sm-9">@Model.User.CreatedAt.ToString("dd/MM/yyyy")</dd>
        </dl>
    </div>

    <form method="post">
        <input type="hidden" asp-for="User.Id" />
        <div class="form-actions">
            <a asp-page="./Index" class="btn btn-secondary">Cancelar</a>
            <button type="submit" class="btn btn-danger">Eliminar</button>
        </div>
    </form>
</div>
</div>
