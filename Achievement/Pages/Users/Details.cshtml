@page "/Users/{id:int}"
@using Achievement.Models
@model Achievement.Pages.Users.DetailsModel
@{
    ViewData["Title"] = Model.ProfileUser.Name;
    var games = Model.ProfileUser.UserGames;
}

<div class="profile">
    <div class="profile-banner" style="@(string.IsNullOrEmpty(Model.ProfileUser.Banner) ? "" : $"background-image:url('/{Model.ProfileUser.Banner}')")">
        @if (Model.IsOwner)
        {
            <form method="post" asp-page-handler="Banner" enctype="multipart/form-data" class="profile-img-form">
                <label class="btn btn-secondary btn-sm">
                    Trocar banner
                    <input type="file" name="BannerFile" accept="image/jpeg,image/png" onchange="this.form.submit()" hidden />
                </label>
            </form>
        }
    </div>

    <div class="profile-head">
        <div class="profile-avatar">
            @if (string.IsNullOrEmpty(Model.ProfileUser.Image))
            {
                <span class="profile-avatar-initials">@(Model.ProfileUser.Name.Substring(0, 1).ToUpper())</span>
            }
            else
            {
                <img src="~/@Model.ProfileUser.Image" alt="Avatar de @Model.ProfileUser.Name" />
            }
            @if (Model.IsOwner)
            {
                <form method="post" asp-page-handler="Avatar" enctype="multipart/form-data" class="profile-avatar-edit">
                    <label title="Trocar foto">
                        ✎
                        <input type="file" name="AvatarFile" accept="image/jpeg,image/png" onchange="this.form.submit()" hidden />
                    </label>
                </form>
            }
        </div>
        <div class="profile-meta">
            <h1>@Model.ProfileUser.Name</h1>
            <p class="text-muted">@games.Count jogo(s) na lista</p>
        </div>
    </div>

    <div asp-validation-summary="All" class="text-danger" style="padding:0 1.5rem;"></div>

    <div class="content-card" style="margin-top:1.5rem;">
        <h2 class="game-section-title">A Lista de @Model.ProfileUser.Name</h2>

        @if (!games.Any())
        {
            <p class="text-muted">Ainda não há jogos guardados na lista.</p>
        }
        else
        {
            foreach (var group in games.GroupBy(ug => ug.Status).OrderBy(g => g.Key))
            {
                <div class="game-section-title">@DetailsModel.StatusName(group.Key) (@group.Count())</div>
                <div class="profile-games">
                    @foreach (var ug in group)
                    {
                        <a class="profile-game" asp-page="/Games/Details" asp-route-id="@ug.Game.Id" asp-route-slug="@ug.Game.Slug">
                            <img src="~/@ug.Game.CoverImage" alt="@ug.Game.Name" />
                            <span>@ug.Game.Name</span>
                        </a>
                    }
                </div>
            }
        }
    </div>
</div>

<style>
    .profile-banner {
        height: 220px;
        border-radius: 12px;
        background: linear-gradient(135deg, #3a2d5c, #1f2a44);
        background-size: cover;
        background-position: center;
        position: relative;
    }
    .profile-img-form { position: absolute; bottom: 12px; right: 12px; }
    .profile-head { display: flex; align-items: flex-end; gap: 1rem; margin: -40px 0 0 1.5rem; }
    .profile-avatar {
        position: relative; width: 110px; height: 110px; border-radius: 50%;
        overflow: hidden; border: 4px solid #181818; background: #4a3a78;
        display: flex; align-items: center; justify-content: center; flex: 0 0 auto;
    }
    .profile-avatar img { width: 100%; height: 100%; object-fit: cover; }
    .profile-avatar-initials { font-size: 2.5rem; color: #fff; font-weight: 700; }
    .profile-avatar-edit { position: absolute; bottom: 4px; right: 4px; }
    .profile-avatar-edit label {
        cursor: pointer; background: #000a; color: #fff; border-radius: 50%;
        width: 28px; height: 28px; display: flex; align-items: center; justify-content: center;
    }
    .profile-meta h1 { margin: 0; }
    .profile-games { display: flex; flex-wrap: wrap; gap: 1rem; margin: .5rem 0 1.5rem; }
    .profile-game { width: 120px; text-decoration: none; color: inherit; }
    .profile-game img { width: 120px; height: 160px; object-fit: cover; border-radius: 8px; }
    .profile-game span { display: block; margin-top: .35rem; font-size: .85rem; }
    .btn-sm { padding: .25rem .6rem; font-size: .8rem; cursor: pointer; }
</style>
