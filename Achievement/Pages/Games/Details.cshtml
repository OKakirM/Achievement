@page "/Games/{id:int}/{slug?}"
@model Achievement.Pages.Games.DetailsModel

@{
    ViewData["Title"] = Model.Game.Name;
}

    <div class="game-detail-banner">
        <img src="~/@Model.Game.BannerImage" alt="Banner de @Model.Game.Name" />
    </div>

<div class="game-detail-head">
    <div class="game-detail-cover">
        <img src="~/@Model.Game.CoverImage" alt="Capa de @Model.Game.Name" />
    </div>

    <div class="game-detail-info">
        <h1 class="game-detail-title">@Model.Game.Name</h1>
        <div class="game-detail-sub">
            <span>@Model.Game.ReleaseDate.ToString("dd/MM/yyyy")</span>
            <span class="dot">•</span><span>@Model.Game.Developer</span>
        </div>

        <div class="game-stats">
            <div class="game-stat">
                <div class="value star">@(Model.Game.Rating.HasValue ? Model.Game.Rating.Value.ToString("0.0") : "—")</div>
                <div class="label">Avaliação</div>
            </div>
            <div class="game-stat">
                <div class="value">@(Model.Game.Length.HasValue ? $"{Model.Game.Length}h" : "—")</div>
                <div class="label">Duração</div>
            </div>
            <div class="game-stat">
                <div class="value">@(Model.Game.Plays?.ToString() ?? "0")</div>
                <div class="label">Jogaram</div>
            </div>
            <div class="game-stat">
                <div class="value">@Model.Game.Reviews.Count</div>
                <div class="label">Reviews</div>
            </div>
        </div>

        <div class="game-section-title">Plataformas</div>
        <div class="tag-list">
            @foreach (var p in Model.Game.Platforms)
            {
                <span class="tag tag-accent">@p.Name</span>
            }
        </div>

        <div class="game-section-title">Géneros</div>
        <div class="tag-list">
            @foreach (var g in Model.Game.Genres)
            {
                <span class="tag">@g.Name</span>
            }
        </div>

        <div class="game-section-title">Descrição</div>
        <p class="game-description">@Model.Game.Description</p>

        <div class="game-detail-actions">
            @if (User.IsInRole("Admin"))
            {
                <a asp-page="./Edit" asp-route-id="@Model.Game.Id" asp-route-slug="@Model.Game.Slug" class="btn-accent">Editar</a>
                <a asp-page="./Delete" asp-route-id="@Model.Game.Id" asp-route-slug="@Model.Game.Slug" class="btn btn-danger">Eliminar</a>
            }

            <a asp-page="./Index" class="btn btn-secondary">Voltar à lista</a>
        </div>
    </div>
</div>

@if (User.Identity?.IsAuthenticated == true)
{
    <div class="content-card" style="margin-top:1.5rem;">
        <h2 class="game-section-title">Minha Lista</h2>
        <form method="post" asp-page-handler="Status" style="display:flex;gap:.75rem;align-items:end;flex-wrap:wrap;">
            <div class="form-group" style="margin:0;">
                <label asp-for="Status" class="control-label"></label>
                <select asp-for="Status" asp-items="Html.GetEnumSelectList<Achievement.Models.GameStatus>()" class="form-select"></select>
            </div>
            <button type="submit" class="btn btn-primary">@(Model.MyEntry == null ? "Adicionar à lista" : "Atualizar estado")</button>
        </form>
    </div>
}

<div class="content-card" style="margin-top:1.5rem;">
    <h2 class="game-section-title">Reviews (@Model.Game.Reviews.Count)</h2>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <form method="post" asp-page-handler="Review" style="margin-bottom:1.5rem;">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="ReviewRating" class="control-label">Nota (0 a 10)</label>
                <input asp-for="ReviewRating" type="number" step="0.1" min="0" max="10" class="form-control" style="max-width:120px;" />
                <span asp-validation-for="ReviewRating" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ReviewText" class="control-label">A tua review</label>
                <textarea asp-for="ReviewText" rows="4" class="form-control" placeholder="O que achaste do jogo?"></textarea>
                <span asp-validation-for="ReviewText" class="text-danger"></span>
            </div>
            <button type="submit" class="btn btn-primary">@(Model.MyReview == null ? "Publicar review" : "Atualizar review")</button>
        </form>
    }
    else
    {
        <p class="text-muted">
            <a asp-area="Identity" asp-page="/Account/Login">Inicia sessão</a> para deixar uma review.
        </p>
    }

    @if (!Model.Game.Reviews.Any())
    {
        <p class="text-muted">Ainda não há reviews. Sê o primeiro!</p>
    }
    else
    {
        foreach (var r in Model.Game.Reviews.OrderByDescending(r => r.Id))
        {
            <div style="border-top:1px solid #2a2a2a;padding:.75rem 0;">
                <div style="display:flex;justify-content:space-between;align-items:center;">
                    <strong>@r.User?.Name</strong>
                    <span class="star">@r.Rating.ToString("0.0")</span>
                </div>
                <p style="margin:.25rem 0 0;">@r.ReviewContent</p>
            </div>
        }
    }
</div>
