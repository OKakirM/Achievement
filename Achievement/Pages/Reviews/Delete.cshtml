@page "/Reviews/Delete/{id:int}"
@model Achievement.Pages.Reviews.DeleteModel

@{
    ViewData["Title"] = "Eliminar Review";
}

<div class="page-header">
    <h1 class="page-title">Eliminar Review</h1>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="content-card">
            <h4 class="mb-3" style="color: var(--danger);">Tens a certeza que queres eliminar esta review?</h4>

            <div class="d-flex gap-3 flex-wrap mb-3">
                @if (!string.IsNullOrWhiteSpace(Model.Review.Game?.CoverImage))
                {
                    <img src="~/@Model.Review.Game.CoverImage" alt="Capa de @Model.Review.Game.Name" class="image-preview" style="max-width:140px;" />
                }
                <dl class="row flex-grow-1 mb-0">
                    <dt class="col-sm-3">Jogo</dt>
                    <dd class="col-sm-9">@Model.Review.Game?.Name</dd>

                    <dt class="col-sm-3">Autor</dt>
                    <dd class="col-sm-9">@Model.Review.User?.Name</dd>

                    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Review.Rating)</dt>
                    <dd class="col-sm-9">@Model.Review.Rating.ToString("0.0")</dd>

                    <dt class="col-sm-3">Data</dt>
                    <dd class="col-sm-9">@Model.Review.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy")</dd>

                    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Review.ReviewContent)</dt>
                    <dd class="col-sm-9">@Model.Review.ReviewContent</dd>
                </dl>
            </div>

            <form method="post">
                <input type="hidden" asp-for="Review.Id" />
                <div class="game-detail-actions">
                    <input type="submit" value="Eliminar" class="btn btn-danger" />
                    <a asp-page="./Index" class="btn btn-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</div>
