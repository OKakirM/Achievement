@page
@model Achievement.Pages.Reviews.EditModel

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Review</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Review.Id" />
            <div class="form-group">
<span class="text-danger">*</span>
                <label asp-for="Review.ReviewContent" class="control-label"></label>
                <input asp-for="Review.ReviewContent" class="form-control" aria-required="true"/>
                <span asp-validation-for="Review.ReviewContent" class="text-danger"></span>
            </div>
            <div class="form-group">
<span class="text-danger">*</span>
                <label asp-for="Review.Rating" class="control-label"></label>
                <input asp-for="Review.Rating" class="form-control" aria-required="true"/>
                <span asp-validation-for="Review.Rating" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Review.GameFK" class="control-label"></label>
                <select asp-for="Review.GameFK" class="form-control" asp-items="ViewBag.GameFK" ></select>
                <span asp-validation-for="Review.GameFK" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Review.UserFK" class="control-label"></label>
                <select asp-for="Review.UserFK" class="form-control" asp-items="ViewBag.UserFK" ></select>
                <span asp-validation-for="Review.UserFK" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="./Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
