@page
@model Achievement.Pages.Platforms.CreateModel
@using Achievement.Models

@{
    ViewData["Title"] = "Nova Plataforma";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Nova Plataforma</h1>
        <p class="page-subtitle">Adiciona uma nova plataforma ao catálogo</p>
    </div>
    <a asp-page="Index" class="btn btn-secondary">Voltar à lista</a>
</div>

<div class="content-card form-shell">
    <form method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <section class="form-section">
            <div class="form-section-legend">Identidade</div>

            <div class="row">
                <div class="form-group col-md-5">
                    <label asp-for="Platform.Type" class="control-label"></label> <span class="req">*</span>
                    <select asp-for="Platform.Type" class="form-select" asp-items="Html.GetEnumSelectList<PlatformType>()" aria-required="true">
                        <option value="">Selecione...</option>
                    </select>
                    <span asp-validation-for="Platform.Type" class="text-danger"></span>
                </div>
                <div class="form-group col-md-7">
                    <label asp-for="Platform.Name" class="control-label"></label> <span class="req">*</span>
                    <input asp-for="Platform.Name" class="form-control" aria-required="true" />
                    <span asp-validation-for="Platform.Name" class="text-danger"></span>
                </div>
            </div>
        </section>

        <section class="form-section">
            <div class="form-section-legend">Detalhes</div>

            <div class="form-group col-md-5">
                <label asp-for="Platform.ReleaseDate" class="control-label"></label>
                <input asp-for="Platform.ReleaseDate" class="form-control" type="date" />
                <span asp-validation-for="Platform.ReleaseDate" class="text-danger"></span>
            </div>
        </section>

        <div class="form-actions">
            <a asp-page="Index" class="btn btn-secondary">Cancelar</a>
            <button type="submit" class="btn-accent">Criar plataforma</button>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
