@page
@model Achievement.Pages.Platforms.CreateModel
@using Achievement.Models

    @{
    ViewData["Title"] = "Create";
    }
        
    <h1>Create</h1>
        
    <h4>Platform</h4>
    <hr />
    <div class="row">
    <div class="col-md-4">
    <form method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <span class="text-danger">*</span>
                <label asp-for="Platform.Type" class="control-label"></label>
                <select asp-for="Platform.Type" class="form-control" asp-items="Html.GetEnumSelectList<PlatformType>()" aria-required="true">
                    <option value="">Selecione...</option>
                </select>
                <span asp-validation-for="Platform.Type" class="text-danger"></span>
            </div>
            <div class="form-group">
                <span class="text-danger">*</span>
                <label asp-for="Platform.Name" class="control-label"></label>
                <input asp-for="Platform.Name" class="form-control" aria-required="true"/>
                <span asp-validation-for="Platform.Name" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Platform.ReleaseDate" class="control-label"></label>
                <input asp-for="Platform.ReleaseDate" class="form-control" type="date" />
                <span asp-validation-for="Platform.ReleaseDate" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
