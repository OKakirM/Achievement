@page
@model Achievement.Pages.Genres.IndexModel

@{
    ViewData["Title"] = "Géneros";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Géneros</h1>
        <p class="page-subtitle">Explora os jogos por categoria</p>
    </div>
    @if (User.IsInRole("Admin"))
    {
        <a asp-page="Create" class="btn-accent"><span>+</span> Novo Género</a>
    }
</div>

@if (Model.Genre == null || Model.Genre.Count == 0)
{
    <div class="games-empty">
        <p>Ainda não há géneros.</p>
        @if (User.IsInRole("Admin"))
        {
            <a asp-page="Create" class="btn-accent">Criar o primeiro género</a>
        }
    </div>
}
else
{
    <div class="genre-grid">
        @foreach (var item in Model.Genre)
        {
            <div class="genre-card">
                <a class="genre-card-link" asp-page="/Games/Index" asp-route-genre="@item.Id">
                    <span class="genre-card-name">@item.Name</span>
                    <span class="genre-card-count">@item.Games.Count @(item.Games.Count == 1 ? "jogo" : "jogos")</span>
                </a>

                @if (User.IsInRole("Admin"))
                {
                    <div class="game-card-actions">
                        <a asp-page="./Edit" asp-route-id="@item.Id" title="Editar"><i class="bi bi-pencil"></i></a>
                        <a asp-page="./Delete" asp-route-id="@item.Id" title="Eliminar"><i class="bi bi-trash"></i></a>
                    </div>
                }
            </div>
        }
    </div>
}
