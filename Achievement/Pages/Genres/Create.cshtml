@page
@model Achievement.Pages.Genres.CreateModel

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>Genre</h4>
<hr />
<div class="row">
    <div class="col-md-6">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <span class="text-danger">*</span>
                <label asp-for="Genre.Name" class="control-label"></label>
                <input asp-for="Genre.Name" class="form-control" aria-required="true" />
                <span asp-validation-for="Genre.Name" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Genre.Description" class="control-label"></label>
                <textarea asp-for="Genre.Description" class="form-control"></textarea>
                <span asp-validation-for="Genre.Description" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Genre.Slug" class="control-label"></label>
                <input asp-for="Genre.Slug" class="form-control" />
                <small class="form-text text-muted">Deixe em branco para gerar automaticamente.</small>
                <span asp-validation-for="Genre.Slug" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
                <a asp-page="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
