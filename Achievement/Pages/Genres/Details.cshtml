@page
@model Achievement.Pages.Genres.DetailsModel

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>Genre</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Genre.Name)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Genre.Name)
        </dd>
    </dl>
</div>
<div>
    <a asp-page="./Edit" asp-route-id="@Model.Genre.Id">Edit</a> |
    <a asp-page="./Index">Back to List</a>
</div>

@if (Model.Games?.Any() == true)
{
    <h3>Jogos</h3>
    <ul>
        @foreach (var g in Model.Games)
        {
            <li>@g.Name</li>
        }
    </ul>
}
